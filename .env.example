# ===== Required =====
# توکن ربات را از @BotFather بگیرید
BOT_TOKEN=
# آیدی عددی ادمین اصلی (از @userinfobot بگیرید)
ADMIN_ID=
# یوزرنیم ربات بدون @ (مثلا: MyVpnBot)
BOT_USERNAME=

# ===== Optional =====
# دیتابیس (پیش‌فرض SQLite، نیازی به تغییر نیست)
DATABASE_URL=sqlite+aiosqlite:///./zendanbot.db
# لاگ کامل برای دیباگ
DEBUG=false
