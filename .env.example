# Telegram Bot
BOT_TOKEN=your_telegram_bot_token
ADMIN_ID=your_admin_telegram_id
BOT_USERNAME=your_bot_username

# Domain for webhook (if using webhook instead of polling)
DOMAIN=yourdomain.com
WEBHOOK_URL=https://yourdomain.com/webhook

# Database (SQLite for easy start, PostgreSQL recommended for prod)
DATABASE_URL=sqlite+aiosqlite:///./zendanbot.db
# For production Postgres (recommended): DATABASE_URL=postgresql+asyncpg://user:pass@localhost/zendanbot
# For MySQL: DATABASE_URL=mysql+aiomysql://user:pass@localhost/zendanbot

# Other settings
DEBUG=true
SECRET_KEY=your_super_secret_key_for_jwt_or_sessions
# Payment gateways keys etc. will be in DB or here
